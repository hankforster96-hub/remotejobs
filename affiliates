<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Affiliate Program — RemoteJobs</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="style.css">
</head>
<body>
<div class="app-shell">
  <aside class="sidebar">
    <div class="sidebar__logo"><span class="logo__mark"></span>RemoteJobs</div>
    <nav class="sidebar__nav">
      <a href="dashboard.html">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
        My Dashboard
      </a>
      <a href="affiliate.html" class="active">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
        Affiliate Program
      </a>
      <a href="admin.html" id="nav-admin" class="hidden">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"></path></svg>
        Admin Panel
      </a>
    </nav>
    <div class="sidebar__bottom">
      <div class="sidebar__plan">
        <div class="label">Affiliate status</div>
        <div class="value" id="sidebar-status">Loading…</div>
      </div>
      <a href="#" id="logout-btn" class="btn btn--ghost btn--sm btn--block" style="color:var(--cream);border-color:var(--border-dark);">Log out</a>
    </div>
  </aside>

  <main class="main">
    <div id="loading-state" style="text-align:center;padding:80px 24px;color:var(--slate);">
      <div style="font-size:2rem;margin-bottom:12px;">⏳</div>
      <p>Loading your affiliate account…</p>
    </div>

    <!-- NOT YET AN AFFILIATE -->
    <div id="join-view" class="hidden">
      <div class="main__head">
        <div><h1>Affiliate Program</h1><p>Earn money by referring new subscribers to RemoteJobs.</p></div>
      </div>

      <!-- How it works -->
      <div class="steps" style="margin-bottom:32px;">
        <div class="step">
          <div class="step__num">STEP 1</div>
          <h3>Join for free</h3>
          <p>Sign up below in seconds. You get a unique referral link instantly.</p>
        </div>
        <div class="step">
          <div class="step__num">STEP 2</div>
          <h3>Share your link</h3>
          <p>Post your link on WhatsApp, Facebook, Twitter, or anywhere your audience is.</p>
        </div>
        <div class="step">
          <div class="step__num">STEP 3</div>
          <h3>Earn per subscriber</h3>
          <p>Every person who subscribes through your link earns you a commission — paid within 10 days of the referral.</p>
        </div>
      </div>

      <!-- Commission table -->
      <div class="job-list" style="margin-bottom:32px;">
        <div class="job-list__head"><h2>Commission structure</h2></div>
        <table class="data-table">
          <thead><tr><th>Plan they subscribe to</th><th>Plan price</th><th>Your commission</th></tr></thead>
          <tbody>
            <tr><td>Starter</td><td>$4/mo</td><td style="color:var(--green);font-weight:700;">$1.00 per signup</td></tr>
            <tr><td>Pro</td><td>$7/mo</td><td style="color:var(--green);font-weight:700;">$2.00 per signup</td></tr>
            <tr><td>Elite</td><td>$10/mo</td><td style="color:var(--green);font-weight:700;">$3.00 per signup</td></tr>
          </tbody>
        </table>
        <div style="padding:16px 20px;font-size:0.85rem;color:var(--text-muted);">Commissions are paid within 10 days of each successful referral via M-Pesa or bank transfer. Minimum payout threshold: $10.</div>
      </div>

      <!-- Join form -->
      <div class="job-list">
        <div class="job-list__head"><h2>Join the affiliate program</h2></div>
        <div style="padding:24px;max-width:480px;">
          <div class="field">
            <label>Your full name</label>
            <input type="text" id="aff-name" placeholder="e.g. John Kamau">
          </div>
          <div class="field">
            <label>Email (auto-filled)</label>
            <input type="email" id="aff-email" readonly style="opacity:0.6;">
          </div>
          <div class="field">
            <label>Choose your referral code</label>
            <input type="text" id="aff-code" placeholder="e.g. JOHN123 (letters and numbers only)" maxlength="20">
            <div style="font-size:0.8rem;color:var(--text-muted);margin-top:6px;">Your link will be: remotejobsu6.vercel.app?ref=YOURCODE</div>
          </div>
          <button class="btn btn--primary" id="join-btn" style="margin-top:8px;">Join affiliate program</button>
        </div>
      </div>
    </div>

    <!-- ACTIVE AFFILIATE DASHBOARD -->
    <div id="affiliate-view" class="hidden">
      <div class="main__head">
        <div><h1>Your affiliate dashboard</h1><p id="head-sub"></p></div>
      </div>

      <!-- Stats -->
      <div class="cards">
        <div class="card">
          <div class="label">Total clicks</div>
          <div class="value" id="stat-clicks">0</div>
          <div class="sub">on your link</div>
        </div>
        <div class="card">
          <div class="label">Signups referred</div>
          <div class="value" id="stat-signups">0</div>
          <div class="sub">paying subscribers</div>
        </div>
        <div class="card">
          <div class="label">Total earned</div>
          <div class="value" id="stat-earned">$0</div>
          <div class="sub">all time</div>
        </div>
        <div class="card">
          <div class="label">Pending payout</div>
          <div class="value" id="stat-pending">$0</div>
          <div class="sub">unpaid balance</div>
        </div>
      </div>

      <!-- Your referral link -->
      <div class="job-list" style="margin-bottom:28px;">
        <div class="job-list__head"><h2>Your referral link</h2></div>
        <div style="padding:24px;">
          <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center;">
            <input type="text" id="ref-link" readonly style="flex:1;min-width:200px;padding:12px 14px;border:1px solid var(--glass-border-strong);border-radius:8px;background:var(--surface);color:var(--text-primary);font-family:var(--font-body);font-size:0.95rem;">
            <button class="btn btn--primary" id="copy-btn">Copy link</button>
          </div>
          <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:14px;">
            <a id="share-whatsapp" href="#" target="_blank" class="btn btn--dark btn--sm">Share on WhatsApp</a>
            <a id="share-twitter" href="#" target="_blank" class="btn btn--dark btn--sm">Share on Twitter/X</a>
            <a id="share-facebook" href="#" target="_blank" class="btn btn--dark btn--sm">Share on Facebook</a>
          </div>
        </div>
      </div>

      <!-- Conversion history -->
      <div class="job-list" style="margin-bottom:28px;">
        <div class="job-list__head">
          <h2>Your referrals</h2>
          <span style="font-size:0.85rem;color:var(--text-muted);" id="conv-count-label"></span>
        </div>
        <div style="overflow-x:auto;">
          <table class="data-table">
            <thead><tr><th>Date</th><th>Plan subscribed</th><th>Commission</th><th>Status</th></tr></thead>
            <tbody id="conv-table-body"></tbody>
          </table>
        </div>
      </div>

      <!-- Payout request -->
      <div class="job-list">
        <div class="job-list__head"><h2>Request payout</h2></div>
        <div style="padding:24px;max-width:480px;">
          <p style="color:var(--text-body);font-size:0.92rem;margin-bottom:18px;">Minimum payout is $10. Once you request a payout, payment is sent within 10 days via M-Pesa or bank transfer.</p>
          <button class="btn btn--success" id="payout-btn">Request payout</button>
        </div>
      </div>
    </div>
  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="app.js"></script>
<script>
  document.getElementById('logout-btn').addEventListener('click', e => { e.preventDefault(); logOut(); });

  let currentUser = null;
  let affiliateData = null;

  async function init() {
    const user = await requireAuth();
    if (!user) return;
    currentUser = user;

    if (user.email.toLowerCase() === CONFIG.ADMIN_EMAIL.toLowerCase()) {
      document.getElementById('nav-admin').classList.remove('hidden');
    }

    document.getElementById('loading-state').classList.add('hidden');

    // Check if already an affiliate
    const sb = getSupabase();
    const { data, error } = await sb
      .from('affiliates')
      .select('*')
      .eq('user_id', user.id)
      .single();

    if (data && !error) {
      affiliateData = data;
      showAffiliateDashboard(data);
    } else {
      showJoinForm(user);
    }
  }

  function showJoinForm(user) {
    document.getElementById('aff-email').value = user.email;
    // Auto-suggest a ref code from their email
    const suggested = user.email.split('@')[0].replace(/[^a-zA-Z0-9]/g,'').toUpperCase().slice(0,10);
    document.getElementById('aff-code').value = suggested;
    document.getElementById('sidebar-status').textContent = 'Not joined';
    document.getElementById('join-view').classList.remove('hidden');
  }

  document.getElementById('join-btn').addEventListener('click', async () => {
    const name = document.getElementById('aff-name').value.trim();
    const code = document.getElementById('aff-code').value.trim().toUpperCase().replace(/[^A-Z0-9]/g,'');

    if (!name) { toast('Please enter your full name.', 'error'); return; }
    if (!code || code.length < 4) { toast('Referral code must be at least 4 characters.', 'error'); return; }

    const btn = document.getElementById('join-btn');
    btn.disabled = true; btn.textContent = 'Joining…';

    const sb = getSupabase();
    const { data, error } = await sb.from('affiliates').insert({
      user_id: currentUser.id,
      email:   currentUser.email,
      name:    name,
      ref_code: code
    }).select().single();

    if (error) {
      toast(error.message.includes('unique') ? 'That referral code is already taken. Try another.' : error.message, 'error');
      btn.disabled = false; btn.textContent = 'Join affiliate program';
      return;
    }

    affiliateData = data;
    toast('Welcome to the affiliate program!', 'success');
    document.getElementById('join-view').classList.add('hidden');
    showAffiliateDashboard(data);
  });

  async function showAffiliateDashboard(aff) {
    document.getElementById('sidebar-status').textContent = 'Active';
    document.getElementById('head-sub').textContent = `Your code: ${aff.ref_code} · Commission per referral: $1–$3`;

    // Stats
    document.getElementById('stat-clicks').textContent = aff.total_clicks || 0;
    document.getElementById('stat-signups').textContent = aff.total_signups || 0;
    document.getElementById('stat-earned').textContent = `$${(aff.total_earned || 0).toFixed(2)}`;
    const pending = (aff.total_earned || 0) - (aff.total_paid || 0);
    document.getElementById('stat-pending').textContent = `$${pending.toFixed(2)}`;

    // Referral link
    const link = `${window.location.origin}/?ref=${aff.ref_code}`;
    document.getElementById('ref-link').value = link;

    // Copy button
    document.getElementById('copy-btn').addEventListener('click', () => {
      navigator.clipboard.writeText(link);
      toast('Link copied to clipboard!', 'success');
    });

    // Share buttons
    const msg = encodeURIComponent(`Get fresh remote job links delivered to your dashboard daily — plans from $4/mo. Check it out: ${link}`);
    document.getElementById('share-whatsapp').href = `https://wa.me/?text=${msg}`;
    document.getElementById('share-twitter').href = `https://twitter.com/intent/tweet?text=${msg}`;
    document.getElementById('share-facebook').href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(link)}`;

    // Load conversions
    const sb = getSupabase();
    const { data: convs } = await sb
      .from('affiliate_conversions')
      .select('*')
      .eq('ref_code', aff.ref_code)
      .order('converted_at', { ascending: false });

    const tbody = document.getElementById('conv-table-body');
    document.getElementById('conv-count-label').textContent = `${(convs||[]).length} referral${(convs||[]).length !== 1 ? 's' : ''}`;

    if (!convs || !convs.length) {
      tbody.innerHTML = `<tr><td colspan="4" style="text-align:center;color:var(--text-muted);padding:32px;">No referrals yet — start sharing your link!</td></tr>`;
    } else {
      convs.forEach(c => {
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td>${new Date(c.converted_at).toLocaleDateString()}</td>
          <td><span class="tier-pill tier-pill--${c.plan}">${c.plan || '—'}</span></td>
          <td style="color:var(--green);font-weight:600;">$${(c.commission||0).toFixed(2)}</td>
          <td><span style="color:${c.paid_out ? 'var(--green)' : 'var(--text-muted)'};">${c.paid_out ? 'Paid' : 'Pending'}</span></td>
        `;
        tbody.appendChild(tr);
      });
    }

    document.getElementById('affiliate-view').classList.remove('hidden');

    // Payout button
    document.getElementById('payout-btn').addEventListener('click', () => {
      if (pending < 10) {
        toast(`Minimum payout is $10. You have $${pending.toFixed(2)} pending.`, 'error');
        return;
      }
      toast(`Payout request of $${pending.toFixed(2)} sent! Payment will be sent to your M-Pesa or bank account within 10 days.`, 'success');
    });
  }

  init();
</script>
</body>
</html>
