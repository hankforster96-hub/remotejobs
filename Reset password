<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Reset Password — RemoteJobs</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="style.css">
</head>
<body>
<div class="auth-shell">
  <div class="auth-shell__visual">
    <a href="index.html" class="logo" style="color:#fff;"><span class="logo__mark"></span>RemoteJobs</a>
    <div>
      <div class="eyebrow">Account security</div>
      <h1 style="font-family:var(--font-display);font-size:2.2rem;font-weight:700;line-height:1.15;margin-bottom:14px;">Set a new password.</h1>
      <p style="color:var(--slate-light);max-width:380px;">Choose a strong password you haven't used before.</p>
    </div>
    <div style="font-size:0.85rem;color:var(--slate-light);">Questions? <a href="mailto:hankforster96@gmail.com" style="color:var(--orange);font-weight:600;">hankforster96@gmail.com</a></div>
  </div>

  <div class="auth-shell__form">
    <div class="auth-card">
      <div id="reset-view">
        <h1>Choose a new password</h1>
        <p class="sub">This link is valid for a limited time only.</p>
        <form id="reset-form">
          <div class="field"><label>New password</label><input type="password" id="new-password" placeholder="At least 6 characters" minlength="6" required></div>
          <div class="field"><label>Confirm password</label><input type="password" id="confirm-password" placeholder="Repeat password" minlength="6" required></div>
          <button type="submit" class="btn btn--primary btn--block" id="reset-btn">Update password</button>
        </form>
      </div>

      <div id="done-view" class="hidden" style="text-align:center;padding:16px 0;">
        <div style="font-size:3rem;margin-bottom:16px;">✅</div>
        <h1 style="margin-bottom:8px;">Password updated</h1>
        <p class="sub">You can now log in with your new password.</p>
        <a href="login.html" class="btn btn--primary btn--block mt-24">Go to login</a>
      </div>

      <div id="invalid-view" class="hidden" style="text-align:center;padding:16px 0;">
        <div style="font-size:3rem;margin-bottom:16px;">⚠️</div>
        <h1 style="margin-bottom:8px;">Link expired</h1>
        <p class="sub">This reset link is invalid or has expired. Please request a new one.</p>
        <a href="login.html" class="btn btn--ghost btn--block mt-24">Back to login</a>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script src="app.js"></script>
<script>
  // Supabase puts the recovery token in the URL hash when the user clicks the email link.
  // The client picks it up automatically and creates a temporary session for password update.
  getSession().then(session => {
    if (!session) {
      document.getElementById('reset-view').classList.add('hidden');
      document.getElementById('invalid-view').classList.remove('hidden');
    }
  });

  document.getElementById('reset-form').addEventListener('submit', async e => {
    e.preventDefault();
    const btn = document.getElementById('reset-btn');
    const pw = document.getElementById('new-password').value;
    const confirm = document.getElementById('confirm-password').value;

    if (pw !== confirm) {
      toast('Passwords do not match.', 'error');
      return;
    }

    btn.disabled = true; btn.textContent = 'Updating…';
    const result = await updatePassword(pw);
    if (result.ok) {
      document.getElementById('reset-view').classList.add('hidden');
      document.getElementById('done-view').classList.remove('hidden');
    } else {
      toast(result.message, 'error');
      btn.disabled = false; btn.textContent = 'Update password';
    }
  });
</script>
</body>
</html>
